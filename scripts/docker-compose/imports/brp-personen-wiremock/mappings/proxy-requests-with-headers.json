{
  "priority": 30,
  "request": {
    "urlPathPattern": "/haalcentraal/api/brp/personen.*",
    "headers": {
      "x-doelbinding": {
        "matches": "BRP.+"
      },
      "x-verwerking": {
        "matches": ".+"
      }
    }
  },
  "response": {
    "proxyBaseUrl": "http://brp-personen-mock:5010",
    "removeProxyRequestHeaders": ["x-doelbinding", "x-verwerking"]
  }
}
