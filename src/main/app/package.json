{
  "name": "app",
  "version": "0.0.3",
  "engines": {
    "node": "22.22.3",
    "npm": "10.9.8"
  },
  "scripts": {
    "ng": "ng",
    "dev": "npm run generate:types:zac-openapi && ng serve --hmr --proxy-config proxy.conf.json",
    "start": "npm run generate:types:zac-openapi && ng serve --proxy-config proxy.conf.json",
    "build": "npm run generate:types:zac-openapi && ng build --configuration=production --base-href=/ && npm run cache-bust",
    "build:dev": "npm run generate:types:zac-openapi && ng build --base-href=/ && npm run cache-bust",
    "cache-bust": "node scripts/cache-busting.js",
    "test:cache-busting": "node scripts/test-cache-busting.js",
    "test": "ng test",
    "test:watch": "ng test --watch --verbose --silent=false",
    "test:ci": "npx jest -t",
    "test:report": "ng test --coverage",
    "lint": "ng lint",
    "lint:unused": "npx ngx-unused . -p tsconfig.json",
    "generate:types:zac-openapi": "npx openapi-typescript ./../../../build/generated/openapi/META-INF/openapi/openapi.json -o ./src/generated/types/zac-openapi-types.d.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.1",
    "@angular/cdk": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/elements": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/material": "22.0.1",
    "@angular/material-moment-adapter": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/platform-browser-dynamic": "22.0.1",
    "@angular/router": "22.0.1",
    "@formio/angular": "9.0.2",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@tanstack/angular-query-experimental": "5.101.0",
    "@tanstack/query-async-storage-persister": "5.101.0",
    "@tanstack/query-persist-client-core": "5.101.0",
    "bootstrap": "5.3.8",
    "moment": "2.30.1",
    "ngx-editor": "18.0.0",
    "ol": "10.9.0",
    "openapi-fetch": "0.17.0",
    "proj4": "2.20.9",
    "rxjs": "7.8.2",
    "ts-pattern": "5.9.0",
    "zone.js": "0.15.1"
  },
  "overrides": {
    "chokidar": "5.0.0",
    "tar": "^7.5.8"
  },
  "devDependencies": {
    "@angular-builders/jest": "22.0.0",
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/language-service": "22.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.21",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "expect-type": "1.3.0",
    "jest": "29.7.0",
    "jest-extended": "7.0.0",
    "jest-junit": "17.0.0",
    "jest-preset-angular": "14.6.2",
    "less": "4.6.6",
    "openapi-typescript": "7.13.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
