{
  "name": "app",
  "version": "0.0.3",
  "engines": {
    "node": "22.23.1",
    "npm": "10.9.8"
  },
  "scripts": {
    "ng": "ng",
    "dev": "npm run generate:types:zac-openapi && ng serve --hmr --proxy-config proxy.conf.json",
    "start": "npm run generate:types:zac-openapi && ng serve --proxy-config proxy.conf.json",
    "build": "npm run generate:types:zac-openapi && ng build --configuration=production --base-href=/ && npm run cache-bust",
    "build:dev": "npm run generate:types:zac-openapi && ng build --base-href=/ && npm run cache-bust",
    "cache-bust": "node scripts/cache-busting.js",
    "test:cache-busting": "node scripts/test-cache-busting.js",
    "test": "ng test",
    "test:watch": "ng test --watch --verbose --silent=false",
    "test:ci": "npx jest --coverage --config jest.config.js --forceExit",
    "test:shard": "npx jest --coverage --config jest.config.js --forceExit",
    "test:report": "ng test --coverage",
    "lint": "ng lint",
    "lint:unused": "npx ngx-unused . -p tsconfig.json",
    "generate:types:zac-openapi": "npx openapi-typescript ./../../../build/generated/openapi/META-INF/openapi/openapi.json -o ./src/generated/types/zac-openapi-types.d.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/elements": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/material-moment-adapter": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@formio/angular": "10.0.1",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@tanstack/angular-query-experimental": "5.101.2",
    "@tanstack/query-async-storage-persister": "5.101.2",
    "@tanstack/query-persist-client-core": "5.101.2",
    "bootstrap": "5.3.8",
    "moment": "2.30.1",
    "ngx-editor": "18.0.0",
    "ol": "10.9.0",
    "openapi-fetch": "0.17.0",
    "proj4": "2.20.9",
    "rxjs": "7.8.2",
    "ts-pattern": "5.9.0",
    "zone.js": "0.15.1"
  },
  "overrides": {
    "ngx-bootstrap": "20.0.2",
    "chokidar": "5.0.0",
    "tar": "^7.5.8",
    "@babel/core": "7.29.7",
    "http-proxy-middleware": "4.1.1",
    "serialize-javascript": "7.0.7",
    "webpack-dev-server": "5.2.5"
  },
  "devDependencies": {
    "@angular-builders/jest": "20.0.0",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/build": "20.3.31",
    "@angular/cli": "20.3.31",
    "@angular/compiler-cli": "20.3.25",
    "@angular/language-service": "20.3.25",
    "@types/jest": "29.5.14",
    "@types/node": "22.20.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "expect-type": "1.4.0",
    "jest": "29.7.0",
    "jest-extended": "7.0.0",
    "jest-junit": "17.0.0",
    "jest-preset-angular": "14.6.2",
    "less": "4.6.7",
    "openapi-typescript": "7.13.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
