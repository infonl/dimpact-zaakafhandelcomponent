{
  "name": "app",
  "version": "0.0.1",
  "engines": {
    "node": "22.23.1",
    "npm": "12.0.0"
  },
  "scripts": {
    "e2e:run": "./node_modules/.bin/cucumber-js -p default",
    "e2e:start": "npm ci --ignore-scripts && npx playwright install --with-deps && npm run e2e:run",
    "e2e:generate:report": "node generate-report.mjs",
    "e2e:extract:metrics": "node extract-metrics.mjs",
    "bdd:ci": "npx bddgen && npx playwright test",
    "bdd": "npx bddgen && npx playwright test --ui"
  },
  "private": true,
  "dependencies": {
    "@cucumber/cucumber": "13.0.0",
    "pdf-parse": "2.4.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "multiple-cucumber-html-reporter": "4.1.0",
    "dotenv": "17.4.2",
    "playwright-bdd": "9.2.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "cucumber.features": ["features/**/*.feature"]
}
